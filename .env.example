# Supabase - https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Site URL (SITE_URL is used server-side for Stripe redirects; falls back to NEXT_PUBLIC_SITE_URL)
# Local: http://localhost:3000 | Production: https://web42.ai
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe — use sk_test_ / pk_test_ for development, sk_live_ / pk_live_ for production
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Live Checklist (manual steps in Stripe Dashboard):
# 1. Activate account: https://dashboard.stripe.com/account/onboarding
# 2. Enable Connect (Express): https://dashboard.stripe.com/connect/accounts/overview
# 3. Configure Connect branding + set ToS URL (https://web42.ai/terms) and Privacy URL (https://web42.ai/privacy)
# 4. Create live webhook at https://dashboard.stripe.com/webhooks
#    Endpoint: https://web42.ai/api/stripe/webhook
#    Events: checkout.session.completed, checkout.session.expired, account.updated, charge.refunded
# 5. Copy live keys above
