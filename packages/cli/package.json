{
  "name": "@web42/cli",
  "version": "0.2.3",
  "description": "CLI for the Web42 Agent Marketplace - push, install, and remix OpenClaw agent packages",
  "type": "module",
  "bin": {
    "web42": "./dist/index.js"
  },
  "scripts": {
    "embed-skills": "bun scripts/embed-skills.ts",
    "build": "npm run embed-skills && tsc",
    "build:binary": "bash scripts/sync-version.sh && npm run embed-skills && bash scripts/build-binaries.sh",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "express": "^5.2.1",
    "glob": "^11.0.0",
    "inquirer": "^9.3.7",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "skills/**"
  ],
  "keywords": [
    "web42",
    "openclaw",
    "ai-agents",
    "marketplace",
    "cli"
  ],
  "license": "MIT"
}
