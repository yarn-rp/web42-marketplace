{
  "name": "@web42/auth",
  "version": "0.1.0",
  "description": "Web42 Auth SDK — token introspection client and Express/Hono middleware helpers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@types/express": "^4.17.21",
    "express": "^4.19.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@a2a-js/sdk": ">=0.3",
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "@a2a-js/sdk": { "optional": true },
    "express": { "optional": true }
  },
  "keywords": ["web42", "auth", "introspection", "jwt", "middleware"],
  "license": "MIT"
}
